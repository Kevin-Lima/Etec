body {
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
    background-color: #f0f0f0;
}

.container {
    text-align: center;
    padding: 15px;
    background-color: orange;
    border-radius: 5px;
}

input, button {
    margin-top: 8px;
    padding: 8px;
    font-size: 16px;
    width: 100%;
    max-width: 200px; 
}

button {
    background-color: #87cefa;
    color: black;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color 0.3s;
}

button:hover {
    background-color: #4682b4;
}

#resultadoTexto {
    margin-top: 12px;
    font-size: 18px;
    color: #333; 
}
