<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.tools.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".DetailActivity">

    <ImageView
        android:id="@+id/ivDetalheFoto"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:background="#E0E0E0"
        android:contentDescription="Foto do item"
        app:srcCompat="@android:drawable/ic_menu_gallery"
        app:layout_constraintTop_toTopOf="parent"/>

    <LinearLayout
        android:id="@+id/containerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/ivDetalheFoto">

        <TextView
            android:id="@+id/tvDetalheNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome do Item"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2D1E18"/>

        <TextView
            android:id="@+id/tvDetalheTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo: --"
            android:textSize="16sp"
            android:textColor="#6D4C41"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvDetalheQuantidade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quantidade: --"
            android:textSize="16sp"
            android:textColor="#6D4C41"
            android:layout_marginTop="4dp"/>

        <RatingBar
            android:id="@+id/rbDetalheNota"
            style="?android:attr/ratingBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:isIndicator="true"
            android:progressTint="#FFB300"
            android:layout_marginTop="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvDetalheDataCriacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastrado em: --/--/----"
            android:textSize="13sp"
            android:textColor="#757575"/>

        <TextView
            android:id="@+id/tvDetalheDataModificacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Última modificação: Nenhuma modificação realizada"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Voltar"
            android:backgroundTint="#757575"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnExcluir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Excluir"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:layout_marginHorizontal="4dp"/>

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar"
            android:backgroundTint="#4E342E"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>