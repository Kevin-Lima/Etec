<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivItemFoto"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Miniatura da degustação"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvItemNome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nome do Item"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#2D1E18"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivItemFoto"
            app:layout_constraintEnd_toStartOf="@id/rbItemNota"/>

        <TextView
            android:id="@+id/tvItemDetalhes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tipo | Qtd: 1"
            android:textSize="13sp"
            android:textColor="#6D4C41"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvItemNome"
            app:layout_constraintStart_toEndOf="@id/ivItemFoto"
            app:layout_constraintEnd_toStartOf="@id/rbItemNota"/>

        <TextView
            android:id="@+id/tvItemData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00/00/0000 00:00"
            android:textSize="11sp"
            android:textColor="#9E9E9E"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvItemDetalhes"
            app:layout_constraintStart_toEndOf="@id/ivItemFoto" />

        <RatingBar
            android:id="@+id/rbItemNota"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="1.0"
            android:isIndicator="true"
            android:progressTint="#FFB300"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>